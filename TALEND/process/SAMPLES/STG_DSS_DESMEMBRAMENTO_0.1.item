    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;&#xD;&#xA;SELECT DISTINCT&#xD;&#xA;     'DESMEMBRAMENTO VARIOS SETORES' AS DS_TIPO,&#xD;&#xA;     TITULO_DSS,&#xD;&#xA;     CASE&#xD;&#xA;       WHEN UPPER(TITULO_DSS) like 'TEMA%LIVRE%' THEN&#xD;&#xA;         NVL(TEMA_LIVRE_DESCRICAO,TITULO_DSS)&#xD;&#xA;       WHEN UPPER(TITULO_DSS) like '%LIVRE%' THEN&#xD;&#xA;         NVL(TEMA_LIVRE_DESCRICAO,TITULO_DSS)&#xD;&#xA;     ELSE&#xD;&#xA;       ''&#xD;&#xA;     END AS TEMA_LIVRE_DESCRICAO,&#xD;&#xA;     DATA_ENVIO_DSS,&#xD;&#xA;     TURNO_DSS,&#xD;&#xA;     CATEGORIA_DSS,&#xD;&#xA;     REGEXP_SUBSTR(STR, EXP, 1, LEVEL) SETOR,&#xD;&#xA;     ROUND(QTDE,4) AS QTDE,&#xD;&#xA;     STR PK_SETOR_ORIG&#xD;&#xA;FROM (&#xD;&#xA;       SELECT&#xD;&#xA;           SETOR_DSS STR, &#xD;&#xA;           '[^|]+' EXP,&#xD;&#xA;           TITULO_DSS,&#xD;&#xA;           CASE&#xD;&#xA;             WHEN UPPER(TITULO_DSS) like 'TEMA%LIVRE%' THEN&#xD;&#xA;               NVL(TEMA_LIVRE_DESCRICAO,TITULO_DSS)&#xD;&#xA;             WHEN UPPER(TITULO_DSS) like '%LIVRE%' THEN&#xD;&#xA;               NVL(TEMA_LIVRE_DESCRICAO,TITULO_DSS)&#xD;&#xA;           ELSE&#xD;&#xA;             ''&#xD;&#xA;           END AS TEMA_LIVRE_DESCRICAO,&#xD;&#xA;           DATA_ENVIO_DSS,&#xD;&#xA;           TURNO_DSS,&#xD;&#xA;           COUNT(DISTINCT PART_DSS_MATRICULA) / (LENGTH(SETOR_DSS) - LENGTH(REPLACE(SETOR_DSS, '|'))) QTDE,  &#xD;&#xA;           CATEGORIA_DSS           &#xD;&#xA;       FROM INOVACAO_LINS.DSS_REALIZADO_APP&#xD;&#xA;       WHERE LENGTH(SETOR_DSS) - LENGTH(REPLACE(SETOR_DSS, '|')) &lt;> 1&#xD;&#xA;           AND TO_DATE(DATA_ENVIO_DSS,'dd/MM/yyyy') >= TRUNC(sysdate) -3&#xD;&#xA;       GROUP BY SETOR_DSS, &#xD;&#xA;           TITULO_DSS,&#xD;&#xA;           CASE&#xD;&#xA;             WHEN UPPER(TITULO_DSS) like 'TEMA%LIVRE%' THEN&#xD;&#xA;               NVL(TEMA_LIVRE_DESCRICAO,TITULO_DSS)&#xD;&#xA;             WHEN UPPER(TITULO_DSS) like '%LIVRE%' THEN&#xD;&#xA;               NVL(TEMA_LIVRE_DESCRICAO,TITULO_DSS)&#xD;&#xA;           ELSE&#xD;&#xA;             ''&#xD;&#xA;           END ,&#xD;&#xA;           DATA_ENVIO_DSS,&#xD;&#xA;           TURNO_DSS,&#xD;&#xA;           CATEGORIA_DSS&#xD;&#xA;     )&#xD;&#xA;CONNECT BY REGEXP_SUBSTR(STR, EXP, 1, LEVEL) IS NOT NULL&#xD;&#xA;&#xD;&#xA;UNION&#xD;&#xA;&#xD;&#xA;SELECT&#xD;&#xA;     'SETOR UNICO' AS DS_TIPO,&#xD;&#xA;     TITULO_DSS,&#xD;&#xA;     CASE&#xD;&#xA;       WHEN UPPER(TITULO_DSS) like 'TEMA%LIVRE%' THEN&#xD;&#xA;         NVL(TEMA_LIVRE_DESCRICAO,TITULO_DSS)&#xD;&#xA;       WHEN UPPER(TITULO_DSS) like '%LIVRE%' THEN&#xD;&#xA;         NVL(TEMA_LIVRE_DESCRICAO,TITULO_DSS)&#xD;&#xA;     ELSE&#xD;&#xA;       ''&#xD;&#xA;     END AS TEMA_LIVRE_DESCRICAO,&#xD;&#xA;     DATA_ENVIO_DSS,&#xD;&#xA;     TURNO_DSS,&#xD;&#xA;     CATEGORIA_DSS,&#xD;&#xA;     REPLACE(SETOR_DSS,'|',''),&#xD;&#xA;     COUNT(DISTINCT PART_DSS_MATRICULA) QTDE,&#xD;&#xA;     SETOR_DSS&#xD;&#xA;FROM INOVACAO_LINS.DSS_REALIZADO_APP &#xD;&#xA;WHERE LENGTH(SETOR_DSS) - LENGTH(REPLACE(SETOR_DSS, '|')) = 1&#xD;&#xA;   AND TO_DATE(DATA_ENVIO_DSS,'dd/MM/yyyy') >= TRUNC(sysdate) -3&#xD;&#xA;GROUP BY TITULO_DSS,&#xD;&#xA;     CASE&#xD;&#xA;       WHEN UPPER(TITULO_DSS) like 'TEMA%LIVRE%' THEN&#xD;&#xA;         NVL(TEMA_LIVRE_DESCRICAO,TITULO_DSS)&#xD;&#xA;       WHEN UPPER(TITULO_DSS) like '%LIVRE%' THEN&#xD;&#xA;         NVL(TEMA_LIVRE_DESCRICAO,TITULO_DSS)&#xD;&#xA;     ELSE&#xD;&#xA;       ''&#xD;&#xA;     END ,&#xD;&#xA;     DATA_ENVIO_DSS,&#xD;&#xA;     TURNO_DSS,&#xD;&#xA;     CATEGORIA_DSS,&#xD;&#xA;     REPLACE(SETOR_DSS,'|',''),&#xD;&#xA;     SETOR_DSS&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false"/>
