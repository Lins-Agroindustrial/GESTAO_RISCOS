    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;  ID,&#xD;&#xA;  CASE &#xD;&#xA;         WHEN UPPER(TITLE) LIKE '%AM%' THEN&#xD;&#xA;            TO_CHAR(TO_DATE(TITLE,'MM/dd/yyyy HH:mi AM'),'yyyy-MM-dd HH24:mi')&#xD;&#xA;         WHEN UPPER(TITLE) LIKE '%PM%' THEN&#xD;&#xA;            TO_CHAR(TO_DATE(TITLE,'MM/dd/yyyy HH:mi PM'),'yyyy-MM-dd HH24:mi')&#xD;&#xA;         WHEN LENGTH(TITLE) = 16 THEN&#xD;&#xA;            TO_CHAR(TO_DATE(TITLE,'dd/MM/yyyy HH24:mi'),'yyyy-MM-dd HH24:mi')&#xD;&#xA;         WHEN LENGTH(TITLE) = 19 THEN&#xD;&#xA;            TO_CHAR(TO_DATE(TITLE,'MM/dd/yyyy HH24:mi:ss'),'yyyy-MM-dd HH24:mi')&#xD;&#xA;         ELSE          &#xD;&#xA;            TO_CHAR(&#xD;&#xA;                TO_DATE(TITLE,'dd\&quot; de\&quot; fmmonth \&quot;de\&quot; YYYY HH24:mi','nls_date_language=portuguese'),&#xD;&#xA;                    'yyyy-MM-dd HH24:mi')&#xD;&#xA;  END AS TITLE,&#xD;&#xA;  INSPETOR,&#xD;&#xA;  ACOMPANHANTE_INSPECAO,&#xD;&#xA;  SETOR,&#xD;&#xA;  DATA,&#xD;&#xA;  STATUS,&#xD;&#xA;  AREA,&#xD;&#xA;  DATAHORAPROCESSAMENTO,&#xD;&#xA;  DATAHORAINCLUSAO &#xD;&#xA;FROM DW_STAGE.SSO_INSP_PLAN_CAB&#xD;&#xA;&quot;"/>
