    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;    INDICE AS CD_INDICE,&#xD;&#xA;    STATUSOP AS FG_STATUS,&#xD;&#xA;    REFERENCIA AS CD_REFERENCIA,&#xD;&#xA;    TO_CHAR(TO_DATE(DATACADASTRO, 'MM/dd/rrrr hh24:mi:ss'), 'yyyy-MM-dd hh24:mi:ss') AS DT_CADASTRO,&#xD;&#xA;    USUARIO AS DS_USUARIO,&#xD;&#xA;    TO_CHAR(TO_DATE(DATAATUALIZACAO, 'dd/MM/rrrr hh24:mi:ss'), 'yyyy-MM-dd hh24:mi:ss') AS DT_ATUALIZACAO,&#xD;&#xA;    TO_CHAR(TO_DATE(DATAATESTADO,'MM/dd/rrrr'), 'yyyy-MM-dd') AS DT_ATESTADO,&#xD;&#xA;    TO_CHAR(TO_DATE(DATACOMUNICADO,'MM/dd/rrrr'), 'yyyy-MM-dd') AS DT_COMUNICADO,&#xD;&#xA;    MATRICULA AS CD_MATRICULA,&#xD;&#xA;    TURNO AS DS_TURNO,&#xD;&#xA;    MOTIVO AS DS_MOTIVO_ISOLAMENTO,&#xD;&#xA;    TO_CHAR(TO_DATE(DATACONTATOSINTOMAS,'MM/dd/rrrr'), 'yyyy-MM-dd') AS DT_CONTATO_SINTOMAS,&#xD;&#xA;    RESULTADOTESTE AS DS_RESULTADO_TESTE,&#xD;&#xA;    SINTOMAS AS DS_SINTOMAS,&#xD;&#xA;    PROCEDIMENTOS AS DS_PROCEDIMENTOS,&#xD;&#xA;    DIASATESTADO AS NR_DIAS_ATESTADO,&#xD;&#xA;    CID AS DS_CID,&#xD;&#xA;    PARECERMEDICO AS DS_PARECER_MEDICO,&#xD;&#xA;    DIAGNSTICOENFERMAGEM AS DS_DIAG_ENFERMAGEM,&#xD;&#xA;    TELEMEDICINA AS DS_TELEMEDICINA,&#xD;&#xA;    TO_CHAR(TO_DATE(DATAPREVISAO,'MM/dd/rrrr'), 'yyyy-MM-dd') AS DT_PREVISAO,&#xD;&#xA;    STATUS AS DS_STATUS,&#xD;&#xA;    NUM_PHONE AS NR_TELEFONE,&#xD;&#xA;    CRM AS DS_CRM,&#xD;&#xA;    MEDICORESPONSAVEL AS DS_MEDICO_RESPONSAVEL,&#xD;&#xA;    OBSERVACAO || OBSERVACAO2 || OBSERVACAO3 || OBSERVACAO4 AS DS_OBSERVACAO,&#xD;&#xA;    MOTIVOCONTATO AS DS_MOTIVO&#xD;&#xA;FROM ARQ_SSO_HIST_COVID &#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false"/>
