    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:SN4V+sWmiVel+5HfM/pg4j8eD94AvfdIrylpHXMVMAdyP7AYlD2riWaBzw=="/>
    <elementParameter field="TEXT" name="JDBC_URL" value="&quot;jdbc:oracle:oci:/@talend&quot;" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;      TO_CHAR(TO_DATE(&#xD;&#xA;      CASE &#xD;&#xA;        WHEN LENGTH(DATA) = 8 THEN&#xD;&#xA;          DATA&#xD;&#xA;        WHEN LENGTH(DATA) = 7 AND INSTR(DATA,'/') = 2 THEN&#xD;&#xA;          '0' || DATA &#xD;&#xA;        WHEN LENGTH(DATA) = 7 AND INSTR(DATA,'/') = 3 THEN&#xD;&#xA;          SUBSTR(DATA,1,3) || '0' ||  SUBSTR(DATA,-4,4) &#xD;&#xA;        WHEN LENGTH(DATA) = 6 AND INSTR(DATA,'/') = 2 THEN&#xD;&#xA;          '0' || SUBSTR(DATA,1,1) || '/0' || SUBSTR( DATA,-4,4) &#xD;&#xA;      ELSE &#xD;&#xA;          NULL  &#xD;&#xA;      END ,'MM/dd/YY'),'yyyy-MM-dd') AS DT_REFERENCIA,&#xD;&#xA;      CASE WHEN LENGTH(HOJ20) - LENGTH(REPLACE(HOJ20, '.', '')) >= 1 AND LENGTH(HOJ20) - LENGTH(REPLACE(HOJ20, ',', '')) >= 1 THEN REPLACE(REPLACE(HOJ20, ',',''),'.',',') ELSE REPLACE(HOJ20,'.',',') END AS HOJ20,&#xD;&#xA;      CASE WHEN LENGTH(HOK20) - LENGTH(REPLACE(HOK20, '.', '')) >= 1 AND LENGTH(HOK20) - LENGTH(REPLACE(HOK20, ',', '')) >= 1 THEN REPLACE(REPLACE(HOK20, ',',''),'.',',') ELSE REPLACE(HOK20,'.',',') END AS HOK20,&#xD;&#xA;      CASE WHEN LENGTH(HOM20) - LENGTH(REPLACE(HOM20, '.', '')) >= 1 AND LENGTH(HOM20) - LENGTH(REPLACE(HOM20, ',', '')) >= 1 THEN REPLACE(REPLACE(HOM20, ',',''),'.',',') ELSE REPLACE(HOM20,'.',',') END AS HOM20,&#xD;&#xA;      CASE WHEN LENGTH(HON20) - LENGTH(REPLACE(HON20, '.', '')) >= 1 AND LENGTH(HON20) - LENGTH(REPLACE(HON20, ',', '')) >= 1 THEN REPLACE(REPLACE(HON20, ',',''),'.',',') ELSE REPLACE(HON20,'.',',') END AS HON20,&#xD;&#xA;      CASE WHEN LENGTH(HOQ20) - LENGTH(REPLACE(HOQ20, '.', '')) >= 1 AND LENGTH(HOQ20) - LENGTH(REPLACE(HOQ20, ',', '')) >= 1 THEN REPLACE(REPLACE(HOQ20, ',',''),'.',',') ELSE REPLACE(HOQ20,'.',',') END AS HOQ20,&#xD;&#xA;      CASE WHEN LENGTH(HOU20) - LENGTH(REPLACE(HOU20, '.', '')) >= 1 AND LENGTH(HOU20) - LENGTH(REPLACE(HOU20, ',', '')) >= 1 THEN REPLACE(REPLACE(HOU20, ',',''),'.',',') ELSE REPLACE(HOU20,'.',',') END AS HOU20,&#xD;&#xA;      CASE WHEN LENGTH(HOV20) - LENGTH(REPLACE(HOV20, '.', '')) >= 1 AND LENGTH(HOV20) - LENGTH(REPLACE(HOV20, ',', '')) >= 1 THEN REPLACE(REPLACE(HOV20, ',',''),'.',',') ELSE REPLACE(HOV20,'.',',') END AS HOV20,&#xD;&#xA;      CASE WHEN LENGTH(HOX20) - LENGTH(REPLACE(HOX20, '.', '')) >= 1 AND LENGTH(HOX20) - LENGTH(REPLACE(HOX20, ',', '')) >= 1 THEN REPLACE(REPLACE(HOX20, ',',''),'.',',') ELSE REPLACE(HOX20,'.',',') END AS HOX20,&#xD;&#xA;      CASE WHEN LENGTH(HOZ20) - LENGTH(REPLACE(HOZ20, '.', '')) >= 1 AND LENGTH(HOZ20) - LENGTH(REPLACE(HOZ20, ',', '')) >= 1 THEN REPLACE(REPLACE(HOZ20, ',',''),'.',',') ELSE REPLACE(HOZ20,'.',',') END AS HOZ20,&#xD;&#xA;      CASE WHEN LENGTH(HOF21) - LENGTH(REPLACE(HOF21, '.', '')) >= 1 AND LENGTH(HOF21) - LENGTH(REPLACE(HOF21, ',', '')) >= 1 THEN REPLACE(REPLACE(HOF21, ',',''),'.',',') ELSE REPLACE(HOF21,'.',',') END AS HOF21,&#xD;&#xA;      CASE WHEN LENGTH(HOG21) - LENGTH(REPLACE(HOG21, '.', '')) >= 1 AND LENGTH(HOG21) - LENGTH(REPLACE(HOG21, ',', '')) >= 1 THEN REPLACE(REPLACE(HOG21, ',',''),'.',',') ELSE REPLACE(HOG21,'.',',') END AS HOG21,&#xD;&#xA;      CASE WHEN LENGTH(HOH21) - LENGTH(REPLACE(HOH21, '.', '')) >= 1 AND LENGTH(HOH21) - LENGTH(REPLACE(HOH21, ',', '')) >= 1 THEN REPLACE(REPLACE(HOH21, ',',''),'.',',') ELSE REPLACE(HOH21,'.',',') END AS HOH21,&#xD;&#xA;      CASE WHEN LENGTH(HOJ21) - LENGTH(REPLACE(HOJ21, '.', '')) >= 1 AND LENGTH(HOJ21) - LENGTH(REPLACE(HOJ21, ',', '')) >= 1 THEN REPLACE(REPLACE(HOJ21, ',',''),'.',',') ELSE REPLACE(HOJ21,'.',',') END AS HOJ21,&#xD;&#xA;      CASE WHEN LENGTH(HOK21) - LENGTH(REPLACE(HOK21, '.', '')) >= 1 AND LENGTH(HOK21) - LENGTH(REPLACE(HOK21, ',', '')) >= 1 THEN REPLACE(REPLACE(HOK21, ',',''),'.',',') ELSE REPLACE(HOK21,'.',',') END AS HOK21,&#xD;&#xA;      CASE WHEN LENGTH(HOM21) - LENGTH(REPLACE(HOM21, '.', '')) >= 1 AND LENGTH(HOM21) - LENGTH(REPLACE(HOM21, ',', '')) >= 1 THEN REPLACE(REPLACE(HOM21, ',',''),'.',',') ELSE REPLACE(HOM21,'.