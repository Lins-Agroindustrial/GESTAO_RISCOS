    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT  &#xD;&#xA;  'DATAINICIOBASE' AS CHAVE,&#xD;&#xA;  CASE WHEN NVL('&quot; + context.PARAMETRODATAINICIO + &quot;','DATAINICIOSAFRA') = 'DATAINICIOSAFRA' THEN&#xD;&#xA;        TO_CHAR( TRUNC(DATAINICIO,'YY'),'yyyy-MM-dd')&#xD;&#xA;   ELSE&#xD;&#xA;        TO_CHAR(TRUNC(SYSDATE) - '&quot; + context.PARAMETRODATAINICIO +&quot;','yyyy-MM-dd') &#xD;&#xA;  END AS VALOR&#xD;&#xA;FROM dw.dm_safra&#xD;&#xA;WHERE ATIVO = 'S'&#xD;&#xA;&#xD;&#xA;union&#xD;&#xA;&#xD;&#xA;select &#xD;&#xA;'DATAHORAPROCESSAMENTO' AS CHAVE,&#xD;&#xA;TO_CHAR(SYSDATE,'YYYY-MM-DD HH24:MI:SS') AS VALOR&#xD;&#xA;from DUAL&#xD;&#xA;&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
