    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:yFuEUv61K8tzOa4Z5+XUNsbthez1jlDdp/wg/rOsBkZb93W5chwusAEghA=="/>
    <elementParameter field="TEXT" name="JDBC_URL" value="&quot;jdbc:oracle:oci:/@talend&quot;" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;        TO_CHAR(&#xD;&#xA;          TO_DATE(&#xD;&#xA;            CASE &#xD;&#xA;               WHEN LENGTH(BZFXPTAX) = 8 THEN&#xD;&#xA;                 BZFXPTAX&#xD;&#xA;               WHEN LENGTH(BZFXPTAX) = 7 AND INSTR(BZFXPTAX,'/') = 2 THEN&#xD;&#xA;                 '0' || BZFXPTAX &#xD;&#xA;               WHEN LENGTH(BZFXPTAX) = 7 AND INSTR(BZFXPTAX,'/') = 3 THEN&#xD;&#xA;                 SUBSTR(BZFXPTAX,1,3) || '0' ||  SUBSTR(BZFXPTAX,-4,4) &#xD;&#xA;               WHEN LENGTH(BZFXPTAX) = 6 AND INSTR(BZFXPTAX,'/') = 2 THEN&#xD;&#xA;                 '0' || SUBSTR(BZFXPTAX,1,1) || '/0' || SUBSTR( BZFXPTAX,-4,4) &#xD;&#xA;           ELSE &#xD;&#xA;               NULL  &#xD;&#xA;           END ,'MM/dd/YY'),'yyyy-MM-dd') AS DT_REFERENCIA,&#xD;&#xA;           CASE WHEN LENGTH(PX_BID) - LENGTH(REPLACE(PX_BID, '.', '')) >= 1 AND LENGTH(PX_BID) - LENGTH(REPLACE(PX_BID, ',', '')) >= 1 THEN REPLACE(REPLACE(PX_BID, ',',''),'.',',') ELSE REPLACE(PX_BID,'.',',') END AS PX_BID,&#xD;&#xA;           CASE WHEN LENGTH(PX_ASK) - LENGTH(REPLACE(PX_ASK, '.', '')) >= 1 AND LENGTH(PX_ASK) - LENGTH(REPLACE(PX_ASK, ',', '')) >= 1 THEN REPLACE(REPLACE(PX_ASK, ',',''),'.',',') ELSE REPLACE(PX_ASK,'.',',') END AS PX_ASK,&#xD;&#xA;           CASE WHEN LENGTH(USDBRL_CURNCY) - LENGTH(REPLACE(USDBRL_CURNCY, '.', '')) >= 1 AND LENGTH(USDBRL_CURNCY) - LENGTH(REPLACE(USDBRL_CURNCY, ',', '')) >= 1 THEN REPLACE(REPLACE(USDBRL_CURNCY, ',',''),'.',',') ELSE REPLACE(USDBRL_CURNCY,'.',',') END AS USDBRL_CURNCY&#xD;&#xA;FROM DW_STAGE.STG_ARQ_RISCOS_DOLAR D&#xD;&#xA;ORDER BY 1&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" value="oracle_id" show="false"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;&quot;"/>
