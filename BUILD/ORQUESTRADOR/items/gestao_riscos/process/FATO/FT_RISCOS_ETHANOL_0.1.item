    <elementParameter field="TEXT" name="USER" value="context.STG_USER"/>
    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:0/nPBb1ZgfqhPAGvQn+WuPWNj5Fv+2uBHrH4oLiSCIE0FqgvyX8WSNNCQg=="/>
    <elementParameter field="TEXT" name="JDBC_URL" value="&quot;jdbc:oracle:oci:/@talend&quot;" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;        TO_CHAR(TO_DATE(&#xD;&#xA;        CASE &#xD;&#xA;          WHEN LENGTH(DATA) = 8 THEN&#xD;&#xA;            DATA&#xD;&#xA;          WHEN LENGTH(DATA) = 7 AND INSTR(DATA,'/') = 2 THEN&#xD;&#xA;            '0' || DATA &#xD;&#xA;          WHEN LENGTH(DATA) = 7 AND INSTR(DATA,'/') = 3 THEN&#xD;&#xA;            SUBSTR(DATA,1,3) || '0' ||  SUBSTR(DATA,-4,4) &#xD;&#xA;          WHEN LENGTH(DATA) = 6 AND INSTR(DATA,'/') = 2 THEN&#xD;&#xA;            '0' || SUBSTR(DATA,1,1) || '/0' || SUBSTR( DATA,-4,4) &#xD;&#xA;        ELSE &#xD;&#xA;            NULL  &#xD;&#xA;        END ,'MM/dd/YY'),'yyyy-MM-dd') AS DT_REFERENCIA,&#xD;&#xA;        CASE WHEN LENGTH(ETHJ19) - LENGTH(REPLACE(ETHJ19, '.', '')) >= 1 AND LENGTH(ETHJ19) - LENGTH(REPLACE(ETHJ19, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHJ19, ',',''),'.',',') ELSE REPLACE(ETHJ19,'.',',') END AS ETHJ19,&#xD;&#xA;        CASE WHEN LENGTH(ETHK19) - LENGTH(REPLACE(ETHK19, '.', '')) >= 1 AND LENGTH(ETHK19) - LENGTH(REPLACE(ETHK19, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHK19, ',',''),'.',',') ELSE REPLACE(ETHK19,'.',',') END AS ETHK19,&#xD;&#xA;        CASE WHEN LENGTH(ETHM19) - LENGTH(REPLACE(ETHM19, '.', '')) >= 1 AND LENGTH(ETHM19) - LENGTH(REPLACE(ETHM19, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHM19, ',',''),'.',',') ELSE REPLACE(ETHM19,'.',',') END AS ETHM19,&#xD;&#xA;        CASE WHEN LENGTH(ETHN19) - LENGTH(REPLACE(ETHN19, '.', '')) >= 1 AND LENGTH(ETHN19) - LENGTH(REPLACE(ETHN19, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHN19, ',',''),'.',',') ELSE REPLACE(ETHN19,'.',',') END AS ETHN19,&#xD;&#xA;        CASE WHEN LENGTH(ETHQ19) - LENGTH(REPLACE(ETHQ19, '.', '')) >= 1 AND LENGTH(ETHQ19) - LENGTH(REPLACE(ETHQ19, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHQ19, ',',''),'.',',') ELSE REPLACE(ETHQ19,'.',',') END AS ETHQ19,&#xD;&#xA;        CASE WHEN LENGTH(ETHU19) - LENGTH(REPLACE(ETHU19, '.', '')) >= 1 AND LENGTH(ETHU19) - LENGTH(REPLACE(ETHU19, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHU19, ',',''),'.',',') ELSE REPLACE(ETHU19,'.',',') END AS ETHU19,&#xD;&#xA;        CASE WHEN LENGTH(ETHV19) - LENGTH(REPLACE(ETHV19, '.', '')) >= 1 AND LENGTH(ETHV19) - LENGTH(REPLACE(ETHV19, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHV19, ',',''),'.',',') ELSE REPLACE(ETHV19,'.',',') END AS ETHV19,&#xD;&#xA;        CASE WHEN LENGTH(ETHX19) - LENGTH(REPLACE(ETHX19, '.', '')) >= 1 AND LENGTH(ETHX19) - LENGTH(REPLACE(ETHX19, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHX19, ',',''),'.',',') ELSE REPLACE(ETHX19,'.',',') END AS ETHX19,&#xD;&#xA;        CASE WHEN LENGTH(ETHZ19) - LENGTH(REPLACE(ETHZ19, '.', '')) >= 1 AND LENGTH(ETHZ19) - LENGTH(REPLACE(ETHZ19, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHZ19, ',',''),'.',',') ELSE REPLACE(ETHZ19,'.',',') END AS ETHZ19,&#xD;&#xA;        CASE WHEN LENGTH(ETHF20) - LENGTH(REPLACE(ETHF20, '.', '')) >= 1 AND LENGTH(ETHF20) - LENGTH(REPLACE(ETHF20, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHF20, ',',''),'.',',') ELSE REPLACE(ETHF20,'.',',') END AS ETHF20,&#xD;&#xA;        CASE WHEN LENGTH(ETHG20) - LENGTH(REPLACE(ETHG20, '.', '')) >= 1 AND LENGTH(ETHG20) - LENGTH(REPLACE(ETHG20, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHG20, ',',''),'.',',') ELSE REPLACE(ETHG20,'.',',') END AS ETHG20,&#xD;&#xA;        CASE WHEN LENGTH(ETHH20) - LENGTH(REPLACE(ETHH20, '.', '')) >= 1 AND LENGTH(ETHH20) - LENGTH(REPLACE(ETHH20, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHH20, ',',''),'.',',') ELSE REPLACE(ETHH20,'.',',') END AS ETHH20,&#xD;&#xA;        CASE WHEN LENGTH(ETHJ20) - LENGTH(REPLACE(ETHJ20, '.', '')) >= 1 AND LENGTH(ETHJ20) - LENGTH(REPLACE(ETHJ20, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHJ20, ',',''),'.',',') ELSE REPLACE(ETHJ20,'.',',') END AS ETHJ20,&#xD;&#xA;        CASE WHEN LENGTH(ETHK20) - LENGTH(REPLACE(ETHK20, '.', '')) >= 1 AND LENGTH(ETHK20) - LENGTH(REPLACE(ETHK20, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHK20, ',',''),'.',',') ELSE REPLACE(ETHK20,'.',',') END AS ETHK20,&#xD;&#xA;        CASE WHEN LENGTH(ETHM20) - LENGT