NGTH(REPLACE(ETHN30, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHN30, ',',''),'.',',') ELSE REPLACE(ETHN30,'.',',') END AS ETHN30,&#xD;&#xA;        CASE WHEN LENGTH(ETHQ30) - LENGTH(REPLACE(ETHQ30, '.', '')) >= 1 AND LENGTH(ETHQ30) - LENGTH(REPLACE(ETHQ30, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHQ30, ',',''),'.',',') ELSE REPLACE(ETHQ30,'.',',') END AS ETHQ30,&#xD;&#xA;        CASE WHEN LENGTH(ETHU30) - LENGTH(REPLACE(ETHU30, '.', '')) >= 1 AND LENGTH(ETHU30) - LENGTH(REPLACE(ETHU30, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHU30, ',',''),'.',',') ELSE REPLACE(ETHU30,'.',',') END AS ETHU30,&#xD;&#xA;        CASE WHEN LENGTH(ETHV30) - LENGTH(REPLACE(ETHV30, '.', '')) >= 1 AND LENGTH(ETHV30) - LENGTH(REPLACE(ETHV30, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHV30, ',',''),'.',',') ELSE REPLACE(ETHV30,'.',',') END AS ETHV30,&#xD;&#xA;        CASE WHEN LENGTH(ETHX30) - LENGTH(REPLACE(ETHX30, '.', '')) >= 1 AND LENGTH(ETHX30) - LENGTH(REPLACE(ETHX30, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHX30, ',',''),'.',',') ELSE REPLACE(ETHX30,'.',',') END AS ETHX30,&#xD;&#xA;        CASE WHEN LENGTH(ETHZ30) - LENGTH(REPLACE(ETHZ30, '.', '')) >= 1 AND LENGTH(ETHZ30) - LENGTH(REPLACE(ETHZ30, ',', '')) >= 1 THEN REPLACE(REPLACE(ETHZ30, ',',''),'.',',') ELSE REPLACE(ETHZ30,'.',',') END AS ETHZ30&#xD;&#xA;FROM DW_STAGE.STG_ARQ_RISCOS_ETHANOL E&#xD;&#xA;ORDER BY 1&#xD;&#xA;&#xD;&#xA;&quot;"/>
