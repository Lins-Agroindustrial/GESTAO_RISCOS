(REPLACE(SBN22, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN22, ',',''),'.',',') ELSE REPLACE(SBN22,'.',',') END AS SBN22,&#xD;&#xA;        CASE WHEN LENGTH(SBV22) - LENGTH(REPLACE(SBV22, '.', '')) >= 1 AND LENGTH(SBV22) - LENGTH(REPLACE(SBV22, ',', '')) >= 1 THEN REPLACE(REPLACE(SBV22, ',',''),'.',',') ELSE REPLACE(SBV22,'.',',') END AS SBV22,&#xD;&#xA;        CASE WHEN LENGTH(SBH23) - LENGTH(REPLACE(SBH23, '.', '')) >= 1 AND LENGTH(SBH23) - LENGTH(REPLACE(SBH23, ',', '')) >= 1 THEN REPLACE(REPLACE(SBH23, ',',''),'.',',') ELSE REPLACE(SBH23,'.',',') END AS SBH23,&#xD;&#xA;        CASE WHEN LENGTH(SBK23) - LENGTH(REPLACE(SBK23, '.', '')) >= 1 AND LENGTH(SBK23) - LENGTH(REPLACE(SBK23, ',', '')) >= 1 THEN REPLACE(REPLACE(SBK23, ',',''),'.',',') ELSE REPLACE(SBK23,'.',',') END AS SBK23,&#xD;&#xA;        CASE WHEN LENGTH(SBN23) - LENGTH(REPLACE(SBN23, '.', '')) >= 1 AND LENGTH(SBN23) - LENGTH(REPLACE(SBN23, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN23, ',',''),'.',',') ELSE REPLACE(SBN23,'.',',') END AS SBN23,&#xD;&#xA;        CASE WHEN LENGTH(SBV23) - LENGTH(REPLACE(SBV23, '.', '')) >= 1 AND LENGTH(SBV23) - LENGTH(REPLACE(SBV23, ',', '')) >= 1 THEN REPLACE(REPLACE(SBV23, ',',''),'.',',') ELSE REPLACE(SBV23,'.',',') END AS SBV23,&#xD;&#xA;        CASE WHEN LENGTH(SBH24) - LENGTH(REPLACE(SBH24, '.', '')) >= 1 AND LENGTH(SBH24) - LENGTH(REPLACE(SBH24, ',', '')) >= 1 THEN REPLACE(REPLACE(SBH24, ',',''),'.',',') ELSE REPLACE(SBH24,'.',',') END AS SBH24,&#xD;&#xA;        CASE WHEN LENGTH(SBK24) - LENGTH(REPLACE(SBK24, '.', '')) >= 1 AND LENGTH(SBK24) - LENGTH(REPLACE(SBK24, ',', '')) >= 1 THEN REPLACE(REPLACE(SBK24, ',',''),'.',',') ELSE REPLACE(SBK24,'.',',') END AS SBK24,&#xD;&#xA;        CASE WHEN LENGTH(SBN24) - LENGTH(REPLACE(SBN24, '.', '')) >= 1 AND LENGTH(SBN24) - LENGTH(REPLACE(SBN24, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN24, ',',''),'.',',') ELSE REPLACE(SBN24,'.',',') END AS SBN24,&#xD;&#xA;        CASE WHEN LENGTH(SBV24) - LENGTH(REPLACE(SBV24, '.', '')) >= 1 AND LENGTH