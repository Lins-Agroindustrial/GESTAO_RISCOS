    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:CkX76x1h2QeATeyTC2wb7RjdWdikJT6cKDPRb7kcdviukjoLtmvgeMUOUw=="/>
    <elementParameter field="TEXT" name="JDBC_URL" value="&quot;jdbc:oracle:oci:/@talend&quot;" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT &#xD;&#xA;        TO_CHAR(TO_DATE(&#xD;&#xA;        CASE &#xD;&#xA;          WHEN LENGTH(DATA) = 8 THEN&#xD;&#xA;            DATA&#xD;&#xA;          WHEN LENGTH(DATA) = 7 AND INSTR(DATA,'/') = 2 THEN&#xD;&#xA;            '0' || DATA &#xD;&#xA;          WHEN LENGTH(DATA) = 7 AND INSTR(DATA,'/') = 3 THEN&#xD;&#xA;            SUBSTR(DATA,1,3) || '0' ||  SUBSTR(DATA,-4,4) &#xD;&#xA;          WHEN LENGTH(DATA) = 6 AND INSTR(DATA,'/') = 2 THEN&#xD;&#xA;            '0' || SUBSTR(DATA,1,1) || '/0' || SUBSTR( DATA,-4,4) &#xD;&#xA;        ELSE &#xD;&#xA;            NULL  &#xD;&#xA;        END ,'MM/dd/YY'),'yyyy-MM-dd') AS DT_REF,&#xD;&#xA;        CASE WHEN LENGTH(SBK12) - LENGTH(REPLACE(SBK12, '.', '')) >= 1 AND LENGTH(SBK12) - LENGTH(REPLACE(SBK12, ',', '')) >= 1 THEN REPLACE(REPLACE(SBK12, ',',''),'.',',') ELSE REPLACE(SBK12,'.',',') END AS SBK12,&#xD;&#xA;        CASE WHEN LENGTH(SBN12) - LENGTH(REPLACE(SBN12, '.', '')) >= 1 AND LENGTH(SBN12) - LENGTH(REPLACE(SBN12, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN12, ',',''),'.',',') ELSE REPLACE(SBN12,'.',',') END AS SBN12,&#xD;&#xA;        CASE WHEN LENGTH(SBV12) - LENGTH(REPLACE(SBV12, '.', '')) >= 1 AND LENGTH(SBV12) - LENGTH(REPLACE(SBV12, ',', '')) >= 1 THEN REPLACE(REPLACE(SBV12, ',',''),'.',',') ELSE REPLACE(SBV12,'.',',') END AS SBV12,&#xD;&#xA;        CASE WHEN LENGTH(SBH13) - LENGTH(REPLACE(SBH13, '.', '')) >= 1 AND LENGTH(SBH13) - LENGTH(REPLACE(SBH13, ',', '')) >= 1 THEN REPLACE(REPLACE(SBH13, ',',''),'.',',') ELSE REPLACE(SBH13,'.',',') END AS SBH13,&#xD;&#xA;        CASE WHEN LENGTH(SBK13) - LENGTH(REPLACE(SBK13, '.', '')) >= 1 AND LENGTH(SBK13) - LENGTH(REPLACE(SBK13, ',', '')) >= 1 THEN REPLACE(REPLACE(SBK13, ',',''),'.',',') ELSE REPLACE(SBK13,'.',',') END AS SBK13,&#xD;&#xA;        CASE WHEN LENGTH(SBN13) - LENGTH(REPLACE(SBN13, '.', '')) >= 1 AND LENGTH(SBN13) - LENGTH(REPLACE(SBN13, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN13, ',',''),'.',',') ELSE REPLACE(SBN13,'.',',') END AS SBN13,&#xD;&#xA;        CASE WHEN LENGTH(SBV13) - LENGTH(REPLACE(SBV13, '.', '')) >= 1 AND LENGTH(SBV13) - LENGTH(REPLACE(SBV13, ',', '')) >= 1 THEN REPLACE(REPLACE(SBV13, ',',''),'.',',') ELSE REPLACE(SBV13,'.',',') END AS SBV13,&#xD;&#xA;        CASE WHEN LENGTH(SBH14) - LENGTH(REPLACE(SBH14, '.', '')) >= 1 AND LENGTH(SBH14) - LENGTH(REPLACE(SBH14, ',', '')) >= 1 THEN REPLACE(REPLACE(SBH14, ',',''),'.',',') ELSE REPLACE(SBH14,'.',',') END AS SBH14,&#xD;&#xA;        CASE WHEN LENGTH(SBK14) - LENGTH(REPLACE(SBK14, '.', '')) >= 1 AND LENGTH(SBK14) - LENGTH(REPLACE(SBK14, ',', '')) >= 1 THEN REPLACE(REPLACE(SBK14, ',',''),'.',',') ELSE REPLACE(SBK14,'.',',') END AS SBK14,&#xD;&#xA;        CASE WHEN LENGTH(SBN14) - LENGTH(REPLACE(SBN14, '.', '')) >= 1 AND LENGTH(SBN14) - LENGTH(REPLACE(SBN14, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN14, ',',''),'.',',') ELSE REPLACE(SBN14,'.',',') END AS SBN14,&#xD;&#xA;        CASE WHEN LENGTH(SBV14) - LENGTH(REPLACE(SBV14, '.', '')) >= 1 AND LENGTH(SBV14) - LENGTH(REPLACE(SBV14, ',', '')) >= 1 THEN REPLACE(REPLACE(SBV14, ',',''),'.',',') ELSE REPLACE(SBV14,'.',',') END AS SBV14,&#xD;&#xA;        CASE WHEN LENGTH(SBH15) - LENGTH(REPLACE(SBH15, '.', '')) >= 1 AND LENGTH(SBH15) - LENGTH(REPLACE(SBH15, ',', '')) >= 1 THEN REPLACE(REPLACE(SBH15, ',',''),'.',',') ELSE REPLACE(SBH15,'.',',') END AS SBH15,&#xD;&#xA;        CASE WHEN LENGTH(SBK15) - LENGTH(REPLACE(SBK15, '.', '')) >= 1 AND LENGTH(SBK15) - LENGTH(REPLACE(SBK15, ',', '')) >= 1 THEN REPLACE(REPLACE(SBK15, ',',''),'.',',') ELSE REPLACE(SBK15,'.',',') END AS SBK15,&#xD;&#xA;        CASE WHEN LENGTH(SBN15) - LENGTH(REPLACE(SBN15, '.', '')) >= 1 AND LENGTH(SBN15) - LENGTH(REPLACE(SBN15, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN15, ',',''),'.',',') ELSE REPLACE(SBN15,'.',',') END AS SBN15,&#xD;&#xA;        CASE WHEN LENGTH(SBV15) - LENGTH(REPLACE(SBV15, '.', '')) >= 1 AND LENGTH(SBV15) - LENGTH(REPLACE(SBV15, ',', '')) >= 1 THEN REPLACE(REPLACE(SBV15, ',',''),'.',',') ELSE REPLACE(SBV15,'.',',') END AS SBV15,&#xD;&#xA;        CASE WHEN LENGTH(SBH16) - LENGTH(REPLACE(SBH16, '.', '')) >= 1 AND LENGTH(SBH16) - LENGTH(REPLACE(SBH16, ',', '')) >= 1 THEN REPLACE(REPLACE(SBH16, ',',''),'.',',') ELSE REPLACE(SBH16,'.',',') END AS SBH16,&#xD;&#xA;        CASE WHEN LENGTH(SBK16) - LENGTH(REPLACE(SBK16, '.', '')) >= 1 AND LENGTH(SBK16) - LENGTH(REPLACE(SBK16, ',', '')) >= 1 THEN REPLACE(REPLACE(SBK16, ',',''),'.',',') ELSE REPLACE(SBK16,'.',',') END AS SBK16,&#xD;&#xA;        CASE WHEN LENGTH(SBN16) - LENGTH(REPLACE(SBN16, '.', '')) >= 1 AND LENGTH(SBN16) - LENGTH(REPLACE(SBN16, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN16, ',',''),'.',',') ELSE REPLACE(SBN16,'.',',') END AS SBN16,&#xD;&#xA;        CASE WHEN LENGTH(SBV16) - LENGTH(REPLACE(SBV16, '.', '')) >= 1 AND LENGTH(SBV16) - LENGTH(REPLACE(SBV16, ',', '')) >= 1 THEN REPLACE(REPLACE(SBV16, ',',''),'.',',') ELSE REPLACE(SBV16,'.',',') END AS SBV16,&#xD;&#xA;        CASE WHEN LENGTH(SBH17) - LENGTH(REPLACE(SBH17, '.', '')) >= 1 AND LENGTH(SBH17) - LENGTH(REPLACE(SBH17, ',', '')) >= 1 THEN REPLACE(REPLACE(SBH17, ',',''),'.',',') ELSE REPLACE(SBH17,'.',',') END AS SBH17,&#xD;&#xA;        CASE WHEN LENGTH(SBK17) - LENGTH(REPLACE(SBK17, '.', '')) >= 1 AND LENGTH(SBK17) - LENGTH(REPLACE(SBK17, ',', '')) >= 1 THEN REPLACE(REPLACE(SBK17, ',',''),'.',',') ELSE REPLACE(SBK17,'.',',') END AS SBK17,&#xD;&#xA;        CASE WHEN LENGTH(SBN17) - LENGTH(REPLACE(SBN17, '.', '')) >= 1 AND LENGTH(SBN17) - LENGTH(REPLACE(SBN17, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN17, ',',''),'.',',') ELSE REPLACE(SBN17,'.',',') END AS SBN17,&#xD;&#xA;        CASE WHEN LENGTH(SBV17) - LENGTH(REPLACE(SBV17, '.', '')) >= 1 AND LENGTH(SBV17) - LENGTH(REPLACE(SBV17, ',', '')) >= 1 THEN REPLACE(REPLACE(SBV17, ',',''),'.',',') ELSE REPLACE(SBV17,'.',',') END AS SBV17,&#xD;&#xA;        CASE WHEN LENGTH(SBH18) - LENGTH(REPLACE(SBH18, '.', '')) >= 1 AND LENGTH(SBH18) - LENGTH(REPLACE(SBH18, ',', '')) >= 1 THEN REPLACE(REPLACE(SBH18, ',',''),'.',',') ELSE REPLACE(SBH18,'.',',') END AS SBH18,&#xD;&#xA;        CASE WHEN LENGTH(SBK18) - LENGTH(REPLACE(SBK18, '.', '')) >= 1 AND LENGTH(SBK18) - LENGTH(REPLACE(SBK18, ',', '')) >= 1 THEN REPLACE(REPLACE(SBK18, ',',''),'.',',') ELSE REPLACE(SBK18,'.',',') END AS SBK18,&#xD;&#xA;        CASE WHEN LENGTH(SBN18) - LENGTH(REPLACE(SBN18, '.', '')) >= 1 AND LENGTH(SBN18) - LENGTH(REPLACE(SBN18, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN18, ',',''),'.',',') ELSE REPLACE(SBN18,'.',',') END AS SBN18,&#xD;&#xA;        CASE WHEN LENGTH(SBV18) - LENGTH(REPLACE(SBV18, '.', '')) >= 1 AND LENGTH(SBV18) - LENGTH(REPLACE(SBV18, ',', '')) >= 1 THEN REPLACE(REPLACE(SBV18, ',',''),'.',',') ELSE REPLACE(SBV18,'.',',') END AS SBV18,&#xD;&#xA;        CASE WHEN LENGTH(SBH19) - LENGTH(REPLACE(SBH19, '.', '')) >= 1 AND LENGTH(SBH19) - LENGTH(REPLACE(SBH19, ',', '')) >= 1 THEN REPLACE(REPLACE(SBH19, ',',''),'.',',') ELSE REPLACE(SBH19,'.',',') END AS SBH19,&#xD;&#xA;        CASE WHEN LENGTH(SBK19) - LENGTH(REPLACE(SBK19, '.', '')) >= 1 AND LENGTH(SBK19) - LENGTH(REPLACE(SBK19, ',', '')) >= 1 THEN REPLACE(REPLACE(SBK19, ',',''),'.',',') ELSE REPLACE(SBK19,'.',',') END AS SBK19,&#xD;&#xA;        CASE WHEN LENGTH(SBN19) - LENGTH(REPLACE(SBN19, '.', '')) >= 1 AND LENGTH(SBN19) - LENGTH(REPLACE(SBN19, ',', '')) >= 1 THEN REPLACE(REPLACE(SBN19, ',',''),'.',',') ELSE REPLACE(SBN19,'.',',') END AS SBN19,&#xD;&#xA;        CASE WHEN LENGTH(SBV19) - LENGTH(REPLACE(SBV19, '.', '')) >= 1 AND LENGTH(SBV19) - LENGTH(REPLACE(SBV19, ',', '')) >= 1 THEN REPLACE(REPLACE(SBV19, ',',''),'.',',') ELSE REPLACE(SBV19,'.',',') END AS SBV19,&#xD;&#xA;        CASE WHEN LENGTH(SBH20) - LENGTH(REPLACE(SBH20, '.', '')) >= 1 AND LENGTH(SBH20) - LENGTH(REPLACE(SBH20, ',', '')) >= 1 THEN REPLACE(REPLACE(SBH20, ',',''),'.',',') ELSE REPLACE(SBH20,'.',',') END AS SBH20,&#xD;&#xA;        CASE WHEN LENGTH(SBK20) - LENGTH(REPLACE(SBK20, '.', '')) >= 1 AND LENGTH(SBK20) - LENGTH(REPLACE(SBK20, 